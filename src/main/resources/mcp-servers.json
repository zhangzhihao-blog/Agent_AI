{
  "mcpServers": {
    "amap-maps": {
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": " API Key"
      }
    },
    "AI-agent-search-mcp-server": {
      "command": "java",
      "args": [
        "-Dspring.ai.mcp.server.stdio=true",
        "-Dspring.main.web-application-type=none",
        "-Dlogging.pattern.console=",
        "-jar",
        "AI-agent-search-mcp-server/target/AI-agent-search-mcp-server-0.0.1-SNAPSHOT.jar"
      ],
      "env": {}
    }

  }
}
